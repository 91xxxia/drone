<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizUsvDeviceMapper">

    <resultMap id="BizUsvDeviceResult" type="BizUsvDevice">
        <id property="deviceId" column="device_id"/>
        <result property="deviceCode" column="device_code"/>
        <result property="deviceName" column="device_name"/>
        <result property="deviceModel" column="device_model"/>
        <result property="enduranceMinutes" column="endurance_minutes"/>
        <result property="cameraSpec" column="camera_spec"/>
        <result property="ownerName" column="owner_name"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectBizUsvDeviceVo">
        select device_id, device_code, device_name, device_model, endurance_minutes, camera_spec, owner_name, status,
               remark, create_by, create_time, update_by, update_time
        from biz_usv_device
    </sql>

    <select id="selectBizUsvDeviceById" parameterType="Long" resultMap="BizUsvDeviceResult">
        <include refid="selectBizUsvDeviceVo"/>
        where device_id = #{deviceId}
    </select>

    <select id="selectBizUsvDeviceList" parameterType="BizUsvDevice" resultMap="BizUsvDeviceResult">
        <include refid="selectBizUsvDeviceVo"/>
        <where>
            <if test="deviceCode != null and deviceCode != ''">and device_code like concat('%', #{deviceCode}, '%')</if>
            <if test="deviceName != null and deviceName != ''">and device_name like concat('%', #{deviceName}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="ownerName != null and ownerName != ''">and owner_name like concat('%', #{ownerName}, '%')</if>
        </where>
        order by device_id desc
    </select>

    <select id="selectBizUsvDeviceByCode" parameterType="String" resultMap="BizUsvDeviceResult">
        <include refid="selectBizUsvDeviceVo"/>
        where device_code = #{deviceCode}
        limit 1
    </select>

    <insert id="insertBizUsvDevice" parameterType="BizUsvDevice" useGeneratedKeys="true" keyProperty="deviceId">
        insert into biz_usv_device(device_code, device_name, device_model, endurance_minutes, camera_spec, owner_name, status, remark, create_by, create_time)
        values(#{deviceCode}, #{deviceName}, #{deviceModel}, #{enduranceMinutes}, #{cameraSpec}, #{ownerName}, #{status}, #{remark}, #{createBy}, sysdate())
    </insert>

    <update id="updateBizUsvDevice" parameterType="BizUsvDevice">
        update biz_usv_device
        <set>
            <if test="deviceName != null and deviceName != ''">device_name = #{deviceName},</if>
            <if test="deviceModel != null">device_model = #{deviceModel},</if>
            <if test="enduranceMinutes != null">endurance_minutes = #{enduranceMinutes},</if>
            <if test="cameraSpec != null">camera_spec = #{cameraSpec},</if>
            <if test="ownerName != null">owner_name = #{ownerName},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where device_id = #{deviceId}
    </update>

    <update id="updateDeviceStatus">
        update biz_usv_device
        set status = #{param2}, update_time = sysdate()
        where device_id = #{param1}
    </update>

    <delete id="deleteBizUsvDeviceById" parameterType="Long">
        delete from biz_usv_device where device_id = #{deviceId}
    </delete>

    <delete id="deleteBizUsvDeviceByIds" parameterType="Long">
        delete from biz_usv_device where device_id in
        <foreach collection="array" item="deviceId" open="(" separator="," close=")">
            #{deviceId}
        </foreach>
    </delete>

</mapper>
